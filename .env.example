# Copy this file to .env and fill in real values before running the app.

# Postgres connection string (e.g. from Neon, Vercel Postgres, or Supabase).
# Use a separate database/branch for local dev vs. production.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random secrets used to sign session cookies. Generate with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=""
VOTER_SESSION_SECRET=""

# Used as an HMAC key when hashing voter access codes before storing them.
ACCESS_CODE_HASH_SECRET=""

# Used once by `npm run db:seed` to create the single admin account.
# Change the password after first login is implemented in a future pass.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""
